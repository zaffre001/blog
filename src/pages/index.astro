---
// CRT 모니터 프론트 — 브라운관(iframe) 속에서 PICO-8 카트가 블로그를 렌더한다.
// 텍스트 모드는 /txt/ 정적 페이지로 분리됐다 (SEO·접근성).
import site from "../../content/site.json";
---

<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8" />
<!-- 앱형 화면: 사파리 더블탭/핀치 확대 차단 (텍스트 모드 /txt/는 확대 허용 유지) -->
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
<title>{site.title}</title>
<meta name="description" content={site.tagline} />
<link rel="alternate" type="application/rss+xml" title={site.title} href="/rss.xml" />
</head>
<body>

<main>
  <section id="rig">
    <div id="monitor">
      <div id="bezel">
        <div id="screen" class="off">
          <iframe id="tube" title="PICO-8 블로그"></iframe>
          <canvas id="glass"></canvas>
          <div class="fx fx-rgb"></div>
          <div class="fx fx-scan"></div>
          <div class="fx fx-vig"></div>
          <div class="fx fx-glare"></div>
          <div id="offglass"></div>
          <div id="bootflash"></div>
        </div>
      </div>
      <div id="chassis-bottom">
        <div id="brand">{site.title} <span>CRT-128</span></div>
        <div id="ctrl">
          <span id="led" title="전원 상태"></span>
          <button id="btn-pico" class="pbtn" aria-pressed="true">PICO-8</button>
          <button id="btn-text" class="pbtn">TEXT</button>
          <button id="btn-power" class="pbtn" title="전원 / 재부팅">⏻</button>
        </div>
      </div>
    </div>
    <div id="deskshadow"></div>
    <p id="tagline">{site.tagline}</p>
    <p id="controls">휠 스크롤 · 클릭으로 열기 · 우클릭/X 뒤로</p>
  </section>
</main>

<!-- 댓글 쓰기 — PC통신 터미널 -->
<div id="cmt-modal" hidden>
  <div id="cmt-term" role="dialog" aria-modal="true" aria-label="댓글 쓰기">
    <div id="cmt-title">《 댓 글 쓰 기 》<span id="cmt-cursor">▌</span></div>
    <div id="cmt-sub">to. <span id="cmt-slug"></span></div>
    <label class="cmt-row">대화명│ <input id="cmt-nick" maxlength="12" placeholder="손님" autocomplete="nickname"></label>
    <div class="cmt-row">내 용│</div>
    <textarea id="cmt-body" maxlength="500" rows="6" spellcheck="false"></textarea>
    <input id="cmt-web" type="text" tabindex="-1" autocomplete="off" aria-hidden="true">
    <div id="cmt-foot">
      <span id="cmt-msg"></span>
      <span>
        <button id="cmt-cancel" type="button">취소<small> ESC</small></button>
        <button id="cmt-send" type="button">등록<small> ⌃⏎</small></button>
      </span>
    </div>
  </div>
</div>

<footer>
  © 2026 {site.title} ·
  <a href="/rss.xml">RSS</a> ·
  <a href="/txt/">텍스트 모드</a> ·
  글꼴 <a href="https://github.com/quiple/galmuri">Galmuri</a> ·
  엔진 <a href="https://www.lexaloffle.com/pico-8.php">PICO-8</a> ·
  <a href="/debug.html">디버그</a>
</footer>

<style is:global>
  @font-face { font-family: "Galmuri7";  src: url("/fonts/Galmuri7.woff2") format("woff2"); }
  @font-face { font-family: "Galmuri11"; src: url("/fonts/Galmuri11.woff2") format("woff2"); font-weight: 400; }
  @font-face { font-family: "Galmuri11"; src: url("/fonts/Galmuri11-Bold.woff2") format("woff2"); font-weight: 700; }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center;
    background:
      radial-gradient(1100px 700px at 50% -12%, #1b2244 0%, #0b0e1e 55%, #06070f 100%);
    font-family: "Galmuri11", monospace;
    color: #c2c3c7;
    padding: 40px 12px 24px;
    touch-action: manipulation;            /* 더블탭 확대 차단 */
    -webkit-tap-highlight-color: transparent;
    overscroll-behavior-y: none;           /* 당겨서 새로고침 방지 */
  }

  /* ── CRT 모니터 ─────────────────────────────── */
  #rig { width: min(640px, 94vw); }
  #monitor {
    background: linear-gradient(175deg, #ece1cb 0%, #dccfaf 55%, #c6b795 100%);
    border-radius: 22px;
    padding: 24px 24px 16px;
    box-shadow:
      inset 0 2px 0 rgba(255,255,255,.65),
      inset 0 -8px 14px rgba(94,80,55,.4),
      0 26px 60px rgba(0,0,0,.65),
      0 4px 14px rgba(0,0,0,.5);
  }
  #bezel {
    background: #17150f;
    border-radius: 14px;
    padding: 12px;
    box-shadow:
      inset 0 5px 16px rgba(0,0,0,.95),
      0 1px 0 rgba(255,255,255,.45);
  }
  #screen {
    position: relative;
    aspect-ratio: 5 / 4;
    border-radius: 12px / 16px;
    overflow: hidden;
    background: #000;
  }
  #tube {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    border: 0; background: #000;
  }
  /* 곡면 유리: 카트 구동 중엔 셰이더가 그린 이 캔버스가 화면이 되고,
     iframe은 투명해진 채 입력만 (역왜곡 좌표로) 전달받는다 */
  #glass {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    display: none; cursor: none;
    touch-action: none; /* 유리 위 터치는 전부 우리가 처리 (스크롤·확대 제스처 차단) */
  }
  #screen.warp #glass { display: block; }
  #screen.warp #tube { opacity: 0; }
  /* 셰이더가 스캔라인·비네트를 곡면으로 직접 그리므로 평면 오버레이는 끔 */
  #screen.warp .fx-rgb, #screen.warp .fx-scan, #screen.warp .fx-vig { display: none; }

  .fx { position: absolute; inset: 0; pointer-events: none; border-radius: inherit; }
  .fx-rgb {
    background: repeating-linear-gradient(90deg,
      rgba(255,60,60,.05) 0 1px, rgba(60,255,60,.04) 1px 2px, rgba(60,60,255,.05) 2px 3px);
  }
  .fx-scan {
    background: repeating-linear-gradient(0deg,
      rgba(0,0,0,0) 0 2px, rgba(0,0,0,.22) 2px 3px);
  }
  .fx-vig {
    background: radial-gradient(ellipse at 50% 45%,
      transparent 56%, rgba(0,0,0,.25) 82%, rgba(0,0,0,.55) 100%);
  }
  .fx-glare {
    background:
      radial-gradient(120% 90% at 18% 6%, rgba(255,255,255,.13), transparent 38%),
      linear-gradient(105deg, rgba(255,255,255,.05) 8%, transparent 30%);
  }
  @keyframes glow { 0%, 100% { opacity: .9; } 50% { opacity: 1; } }
  .fx-vig { animation: glow 6s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) { .fx-vig { animation: none; } }

  /* 꺼진 브라운관 */
  #offglass {
    position: absolute; inset: 0; display: none;
    background: radial-gradient(90% 72% at 50% 42%, #12161d 0%, #05070a 75%);
  }
  #offglass::after {
    content: ""; position: absolute; left: 9%; top: 7%;
    width: 34%; height: 24%;
    background: linear-gradient(rgba(255,255,255,.055), transparent);
    border-radius: 50% / 60%;
    transform: rotate(-16deg);
  }
  #screen.off #offglass { display: block; }
  #screen.off #tube { visibility: hidden; }

  /* 전원 플래시 (WebGL 폴백용) */
  #bootflash {
    position: absolute; left: 4%; right: 4%; top: 50%; height: 2px;
    background: #fff; opacity: 0; pointer-events: none;
  }
  #screen.booting #bootflash { animation: boot .45s ease-out; }
  @keyframes boot {
    0%   { opacity: 1; transform: scaleX(.02); }
    55%  { opacity: 1; transform: scaleX(1); }
    100% { opacity: 0; transform: scaleX(1) scaleY(16); }
  }

  /* 섀시 하단부 */
  #chassis-bottom {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 14px; padding: 0 4px;
  }
  #brand {
    font-weight: 700; font-size: 14px; letter-spacing: 1px;
    color: #6b5c40; text-shadow: 0 1px 0 rgba(255,255,255,.5);
  }
  #brand span { font-weight: 400; font-size: 11px; color: #8d7d5e; }
  #ctrl { display: flex; gap: 8px; align-items: center; }
  #led {
    width: 9px; height: 9px; border-radius: 50%;
    background: #5a5245; margin-right: 4px;
    box-shadow: inset 0 1px 2px rgba(0,0,0,.6);
  }
  #led.wait { background: #e43b44; box-shadow: 0 0 8px rgba(228,59,68,.85); }
  #led.on   { background: #43d94e; box-shadow: 0 0 8px rgba(67,217,78,.85); }

  .pbtn {
    font-family: inherit; font-size: 12px; font-weight: 700; color: #5b4c33;
    white-space: nowrap;
    background: linear-gradient(#f6eeda, #dccfaf);
    border: 1px solid #a3906c; border-radius: 7px;
    padding: 7px 12px 6px; cursor: pointer;
    box-shadow: 0 3px 0 #a3906c, inset 0 1px 0 rgba(255,255,255,.8);
  }
  .pbtn:active, .pbtn[aria-pressed="true"] {
    transform: translateY(2px);
    box-shadow: 0 1px 0 #a3906c, inset 0 2px 3px rgba(0,0,0,.18);
  }
  .pbtn[aria-pressed="true"] { background: linear-gradient(#d3c4a1, #c2b28d); }

  #deskshadow {
    width: min(560px, 80vw); height: 26px; margin: -4px auto 0;
    background: radial-gradient(50% 100% at 50% 0%, rgba(0,0,0,.55), transparent 70%);
    filter: blur(6px);
  }
  #tagline {
    margin-top: 20px; text-align: center;
    font-size: 14px; color: #8a94b8;
  }
  #controls {
    margin-top: 7px; text-align: center;
    font-size: 11px; color: #3f4a66; letter-spacing: .5px;
  }

  @media (max-width: 480px) {
    #brand { font-size: 12px; }
    #brand span { display: block; }
    .pbtn { padding: 6px 9px 5px; font-size: 11px; }
  }

  footer { margin-top: 26px; font-size: 11px; color: #4a5470; }
  footer a { color: #6f7a9e; }
  [hidden] { display: none !important; }

  /* ── 댓글 쓰기 모달 (PC통신 터미널) ── */
  #cmt-modal {
    position: fixed; inset: 0; z-index: 50;
    background: rgba(0, 0, 0, .72);
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
  }
  #cmt-term {
    width: min(440px, 94vw);
    background: #0000a8; color: #e8e8e8;
    border: 4px double #55ffff;
    box-shadow: 0 0 0 3px #000060, 0 24px 60px rgba(0, 0, 0, .75);
    font-size: 14px;
    padding: 14px 16px 12px;
  }
  #cmt-title { text-align: center; color: #ffff55; font-weight: 700; letter-spacing: 2px; }
  #cmt-cursor { color: #fff; animation: cblink 1s steps(1) infinite; }
  @keyframes cblink { 50% { opacity: 0; } }
  #cmt-sub { text-align: center; color: #55ffff; font-size: 12px; margin: 2px 0 12px; }
  .cmt-row { display: block; color: #55ffff; margin: 8px 0 4px; font-size: 13px; }
  #cmt-nick {
    background: transparent; border: 0; border-bottom: 1px dashed #5555ff;
    color: #fff; font: inherit; caret-color: #ffff55; outline: none; width: 11em;
  }
  #cmt-body {
    width: 100%; background: rgba(0, 0, 0, .28);
    border: 1px solid #5555ff; color: #fff;
    font: inherit; line-height: 1.7; padding: 8px;
    caret-color: #ffff55; outline: none; resize: vertical;
  }
  #cmt-web { position: absolute; left: -9999px; }
  #cmt-foot { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; gap: 8px; }
  #cmt-msg { color: #ff5555; font-size: 12px; min-height: 1em; }
  #cmt-foot button {
    font: inherit; font-size: 13px; color: #0000a8; background: #a8a8a8;
    border: 0; padding: 4px 10px; cursor: pointer;
    box-shadow: 2px 2px 0 #000;
  }
  #cmt-foot button:hover { background: #fff; }
  #cmt-foot button small { color: #333; font-size: 10px; }
</style>

<script is:inline>
(() => {
"use strict";
const $ = s => document.querySelector(s);
const PLAYER = "/player/blog.html";
let idxCache = null;

// ── PICO-8 브라운관 ────────────────────────────────
function powerOn(slug, auto) {
  const tube = $("#tube");
  const screen = $("#screen");
  tubeStarted = false;
  tube.src = PLAYER + (slug ? "#" + slug : "");
  screen.classList.remove("off");
  warpOn(); // 곡면 유리 즉시 가동 — 부팅 전엔 자체 스플래시를 띄운다
  if (!warpActive) { // WebGL 폴백: 평면 부팅 플래시
    screen.classList.add("booting");
    setTimeout(() => screen.classList.remove("booting"), 500);
  }
  tube.onload = () => {
    if (!auto) return; // 첫 진입은 스플래시 클릭이 곧 전원 스위치 (오디오 정책)
    try {
      tube.contentWindow.p8_create_audio_context();
      tube.contentWindow.p8_run_cart();
      tubeStarted = true;
    } catch (e) { /* 스플래시 클릭으로 폴백 */ }
  };
}

function powerOff() {
  warpOff();
  $("#tube").removeAttribute("src");
  $("#screen").classList.add("off");
}

// 브라운관 안 카트가 지금 보고 있는 글 (bridge가 iframe 해시에 기록)
function tubeSlug() {
  try {
    const h = $("#tube").contentWindow.location.hash.slice(1);
    return h && !h.startsWith("txt") ? h : null;
  } catch (e) { return null; }
}

// ── 곡면 브라운관 (WebGL 배럴 왜곡) ─────────────────
// PICO-8에는 CRT 필터가 없으므로 (0.2.7 매뉴얼·웹 플레이어 전수 검색으로 확인) 직접 구현.
// 카트 구동이 감지되면 iframe을 투명하게 하고, 그 안의 128x128 캔버스를
// 매 프레임 텍스처로 떠서 배럴 왜곡 + 곡면 스캔라인으로 다시 그린다.
// 입력은 유리 위 좌표를 같은 왜곡식으로 변환해 iframe 캔버스로 전달.
const K = 0.07; // 곡률
const RM = matchMedia("(prefers-reduced-motion: reduce)").matches;
const glass = $("#glass");
let gl = null, warpActive = false, rafId = 0;
let uOff = null, uTime = null;
let offT = 0;            // 0=화면 열림, 1=완전히 꺼짐(점)
let tubeStarted = false; // p8_run_cart 호출 여부 — 전이면 자체 스플래시를 띄운다

function innerCanvas() {
  try { return $("#tube").contentWindow.document.querySelector("canvas"); }
  catch (e) { return null; }
}

// 자체 스플래시 (템플릿의 DOM 스플래시는 곡면을 못 타므로 직접 그린다)
const spl = document.createElement("canvas");
spl.width = spl.height = 128;
const sctx = spl.getContext("2d");
function drawSplash(now) {
  sctx.fillStyle = "#000";
  sctx.fillRect(0, 0, 128, 128);
  sctx.textAlign = "center";
  sctx.fillStyle = "#ffec27";
  sctx.font = "700 12px Galmuri11";
  sctx.fillText("za66re", 64, 34);
  // 미니 카트리지
  sctx.fillStyle = "#c2c3c7"; sctx.fillRect(49, 48, 30, 24);
  sctx.fillStyle = "#fff1e8"; sctx.fillRect(52, 51, 24, 12);
  const stripe = ["#ff004d", "#ffa300", "#ffec27", "#00e436", "#29adff", "#83769c"];
  for (let i = 0; i < 6; i++) { sctx.fillStyle = stripe[i]; sctx.fillRect(52 + i * 4, 65, 4, 4); }
  if (now % 1200 < 700) {
    sctx.fillStyle = "#fff1e8";
    sctx.font = "8px Galmuri7";
    sctx.fillText("클릭해서 전원 ON", 64, 100);
  }
}

// 플리커 = 카메라로 CRT를 찍을 때 생기는 롤링 밴드 (주사율-셔터 간섭).
// 어두운 가로 밴드가 ~3초 주기로 아래로 흘러내린다. 셰이더에서 시간 유니폼으로 계산.

// offT 트윈 (끄기: 0→1, 켜기: 1→0)
function tweenOff(target, dur, cb) {
  if (RM) { offT = target; cb && cb(); return; }
  const from = offT, t0 = performance.now();
  (function step() {
    const u = Math.min(1, (performance.now() - t0) / dur);
    const e = u < .5 ? 2 * u * u : 1 - Math.pow(-2 * u + 2, 2) / 2;
    offT = from + (target - from) * e;
    if (u < 1) requestAnimationFrame(step);
    else { offT = target; cb && cb(); }
  })();
}

function initGL() {
  if (gl) return true;
  gl = glass.getContext("webgl", { antialias: false, depth: false });
  if (!gl) return false;
  const vs = "attribute vec2 a;varying vec2 v;void main(){v=a*.5+.5;gl_Position=vec4(a,0.,1.);}";
  const fs =
    "precision mediump float;varying vec2 v;uniform sampler2D t;uniform float k,o,tm,fk;" +
    "void main(){" +
    "vec2 p0=v*2.-1.;" +
    "vec2 p=p0;" +
    "float oy=clamp(o/.8,0.,1.);" +                     // 끄기 1단계: 세로 붕괴
    "float ox=clamp((o-.8)/.2,0.,1.);" +                // 끄기 2단계: 가로 붕괴(점)
    "p.y/=max(1e-3,1.-oy*.995);" +
    "p.x/=max(1e-3,1.-ox*.99);" +
    "vec2 q=p*(1.+k*dot(p,p));" +                       // 배럴 왜곡
    "vec2 uv=q*.5+.5;" +
    "if(uv.x<0.||uv.x>1.||uv.y<0.||uv.y>1.){gl_FragColor=vec4(0.,0.,0.,1.);return;}" +
    "vec3 c=texture2D(t,uv).rgb;" +
    "float row=uv.y*128.;" +
    "c*=.8+.2*abs(sin(3.14159*row));" +                 // 곡면을 따라 휘는 스캔라인
    "c*=.95+.05*sin(gl_FragCoord.x*2.094);" +           // 옅은 rgb 마스크
    "float ph=fract(v.y+tm*.3);" +                      // 카메라 롤링 밴드 (아래로 흐름)
    "float band=smoothstep(0.,.12,ph)*smoothstep(.32,.19,ph);" +
    "c*=1.-fk*band;" +
    "c*=1.-.22*pow(dot(p0,p0),1.5);" +                  // 비네트 (원좌표 기준)
    "c*=1.+2.2*o;" +                                    // 붕괴선 발광
    "gl_FragColor=vec4(c*1.13,1.);}";                   // 밝기 보상
  const sh = (ty, src) => {
    const s = gl.createShader(ty);
    gl.shaderSource(s, src); gl.compileShader(s);
    return s;
  };
  const prog = gl.createProgram();
  gl.attachShader(prog, sh(gl.VERTEX_SHADER, vs));
  gl.attachShader(prog, sh(gl.FRAGMENT_SHADER, fs));
  gl.linkProgram(prog);
  if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) { gl = null; return false; }
  gl.useProgram(prog);
  gl.bindBuffer(gl.ARRAY_BUFFER, gl.createBuffer());
  gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
  const loc = gl.getAttribLocation(prog, "a");
  gl.enableVertexAttribArray(loc);
  gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);
  gl.bindTexture(gl.TEXTURE_2D, gl.createTexture());
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.NEAREST);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.NEAREST);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
  gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
  gl.pixelStorei(gl.UNPACK_FLIP_Y_WEBGL, true);
  gl.uniform1f(gl.getUniformLocation(prog, "k"), K);
  gl.uniform1f(gl.getUniformLocation(prog, "fk"), RM ? 0 : 0.12); // 밴드 깊이
  uOff = gl.getUniformLocation(prog, "o");
  uTime = gl.getUniformLocation(prog, "tm");
  return true;
}

function warpLoop() {
  rafId = requestAnimationFrame(warpLoop);
  if (!gl) return;
  const now = performance.now();
  // 텍스처 소스: 부팅 전엔 자체 스플래시, 이후엔 카트 캔버스
  let src = spl;
  if (tubeStarted) {
    const c = innerCanvas();
    if (c && c.width > 0) src = c;
  } else {
    drawSplash(now);
  }
  const dpr = Math.min(devicePixelRatio || 1, 2);
  const w = Math.round(glass.clientWidth * dpr), h = Math.round(glass.clientHeight * dpr);
  if (glass.width !== w || glass.height !== h) {
    glass.width = w; glass.height = h;
    gl.viewport(0, 0, w, h);
  }
  gl.uniform1f(uOff, offT);
  gl.uniform1f(uTime, now / 1000);
  try { gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, src); }
  catch (e) { return; }
  gl.drawArrays(gl.TRIANGLES, 0, 3);
}

function warpOn() {
  if (warpActive) return;
  if (!initGL()) return; // WebGL 없으면 평면 오버레이 폴백
  warpActive = true;
  $("#screen").classList.add("warp");
  offT = 1;                // 켜짐 연출: 선에서 화면이 펼쳐진다
  tweenOff(0, 420);
  warpLoop();
}

function warpOff() {
  if (!warpActive) return;
  warpActive = false;
  cancelAnimationFrame(rafId);
  $("#screen").classList.remove("warp");
}

// 유리 위 입력 → 왜곡식을 그대로 적용해 iframe 캔버스 좌표로 전달
function fwdMouse(e, type) {
  const c = innerCanvas();
  if (!c) return;
  const g = glass.getBoundingClientRect();
  const px = ((e.clientX - g.left) / g.width) * 2 - 1;
  const py = ((e.clientY - g.top) / g.height) * 2 - 1;
  const f = 1 + K * (px * px + py * py);
  const qx = Math.max(-1, Math.min(1, px * f));
  const qy = Math.max(-1, Math.min(1, py * f));
  const r = c.getBoundingClientRect();
  c.dispatchEvent(new MouseEvent(type, {
    clientX: r.left + (qx * .5 + .5) * r.width,
    clientY: r.top + (qy * .5 + .5) * r.height,
    button: e.button, buttons: e.buttons, bubbles: true,
  }));
}

// 스플래시 상태에서 유리 클릭 = 전원 (같은 출처라 부팅 함수 직접 호출)
function bootTube() {
  try {
    const w = $("#tube").contentWindow;
    if (typeof w.p8_run_cart !== "function") return;
    w.p8_create_audio_context();
    w.p8_run_cart();
    tubeStarted = true;
  } catch (e) {}
}

glass.addEventListener("mousemove", e => { if (tubeStarted) fwdMouse(e, "mousemove"); });
glass.addEventListener("mousedown", e => {
  e.preventDefault(); // 포커스를 뺏지 않는다 (키보드는 iframe이 계속 받도록)
  try { $("#tube").contentWindow.focus(); } catch (err) {}
  if (!tubeStarted) { bootTube(); return; }
  fwdMouse(e, "mousedown");
});
glass.addEventListener("mouseup", e => fwdMouse(e, "mouseup"));
glass.addEventListener("contextmenu", e => e.preventDefault());
glass.addEventListener("wheel", e => {
  e.preventDefault();
  const c = innerCanvas();
  if (!c) return;
  const r = c.getBoundingClientRect();
  // deltaMode 정규화(줄/페이지 → px) 후 브릿지에 전달
  const dy = e.deltaMode === 1 ? e.deltaY * 16 : e.deltaMode === 2 ? e.deltaY * 128 : e.deltaY;
  c.dispatchEvent(new WheelEvent("wheel", {
    deltaY: dy, clientX: r.left + r.width / 2, clientY: r.top + r.height / 2,
    bubbles: true, cancelable: true,
  }));
}, { passive: false });

// ── 터치: 탭=클릭 · 드래그=스크롤(손가락 1:1 추적) · 길게 누르기=뒤로 ──
// 유리에는 마우스 리스너만 있으므로 터치를 마우스/휠 이벤트로 번역해 자신에게 쏜다.
// preventDefault로 브라우저의 마우스 에뮬레이션·기본 제스처(확대/스크롤)를 차단.
let tch = null;
const mev = (type, x, y, button, buttons) =>
  glass.dispatchEvent(new MouseEvent(type, { clientX: x, clientY: y, button, buttons, bubbles: true, cancelable: true }));

glass.addEventListener("touchstart", e => {
  e.preventDefault();
  if (e.touches.length > 1) { tch = null; return; } // 멀티터치(핀치)는 무시
  const t = e.touches[0];
  tch = { x: t.clientX, y: t.clientY, py: t.clientY, t0: performance.now(), moved: false };
}, { passive: false });

glass.addEventListener("touchmove", e => {
  e.preventDefault();
  if (!tch) return;
  const t = e.touches[0];
  if (Math.abs(t.clientX - tch.x) > 8 || Math.abs(t.clientY - tch.y) > 8) tch.moved = true;
  const dy = tch.py - t.clientY;
  tch.py = t.clientY;
  if (tch.moved && dy !== 0) {
    const r = glass.getBoundingClientRect();
    // 콘텐츠가 손가락을 1:1로 따라오도록 환산
    // (유리폭=128콘텐츠px, 카트 12px/유닛, 브릿지 200deltaY/유닛 → dy×128×200/12/유리폭)
    glass.dispatchEvent(new WheelEvent("wheel", {
      deltaY: dy * 2133 / r.width,
      clientX: t.clientX, clientY: t.clientY, bubbles: true, cancelable: true,
    }));
  }
}, { passive: false });

glass.addEventListener("touchend", e => {
  e.preventDefault();
  if (!tch) return;
  const { x, y, moved, t0 } = tch;
  tch = null;
  if (moved) return; // 드래그였음 — 클릭 아님
  const long = performance.now() - t0 >= 500; // 길게 누르기 = 우클릭(뒤로)
  const button = long ? 2 : 0, buttons = long ? 2 : 1;
  mev("mousemove", x, y, 0, 0);
  mev("mousedown", x, y, button, buttons);
  setTimeout(() => mev("mouseup", x, y, button, 0), 80); // 카트가 프레임에서 읽도록 1프레임+ 유지
}, { passive: false });

glass.addEventListener("touchcancel", () => { tch = null; });

// 사파리 핀치 줌 차단 (gesture 이벤트는 사파리 전용)
addEventListener("gesturestart", e => e.preventDefault());

// ── 진입/이동 ──────────────────────────────────────
function goPico(slug, auto) {
  history.replaceState(null, "", slug ? "#" + slug : location.pathname);
  powerOn(slug, auto);
}

async function getIndex() {
  if (!idxCache) idxCache = await (await fetch("/content/index.json")).json();
  return idxCache;
}

// ── 전원 LED + UI 채널: 카트 상태(gpio[126])·요청(gpio[124])을 훔쳐본다 ──────
setInterval(() => {
  const led = $("#led");
  if (!$("#tube").getAttribute("src")) { led.className = ""; warpOff(); return; }
  let st = 0, ui = 0;
  try {
    const gp = $("#tube").contentWindow.pico8_gpio;
    st = gp?.[126] || 0;
    ui = gp?.[124] || 0;
    if (ui === 1) gp[124] = 0; // 요청 소비
  } catch (e) {}
  if (st > 0) tubeStarted = true; // 안전망 (어떤 경로로든 구동 감지)
  if (ui === 1) openCmt(tubeSlug());
  led.className = st > 0 ? "on" : "wait";
}, 500);

// ── 댓글 쓰기 모달 (PC통신 터미널) ──────────────────
let cmtSlug = null;
function openCmt(slug) {
  if (!slug) return;
  cmtSlug = slug;
  $("#cmt-slug").textContent = slug;
  $("#cmt-msg").textContent = "";
  $("#cmt-modal").hidden = false;
  $("#cmt-body").focus();
}
function closeCmt() { $("#cmt-modal").hidden = true; }
async function sendCmt() {
  const body = $("#cmt-body").value.trim();
  if (!body) { $("#cmt-msg").textContent = "내용을 입력하세요"; return; }
  $("#cmt-send").disabled = true;
  try {
    const r = await fetch("/api/comments/" + cmtSlug, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ nick: $("#cmt-nick").value, body, website: $("#cmt-web").value }),
    });
    const d = await r.json().catch(() => ({}));
    if (!r.ok || d.error) throw new Error(d.error || "전송 실패");
    $("#cmt-body").value = "";
    closeCmt();
    // 카트에 "댓글 갱신됨" 신호 — 스크롤 유지한 채 다시 그린다
    try { $("#tube").contentWindow.pico8_gpio[124] = 2; } catch (e) {}
  } catch (e) {
    $("#cmt-msg").textContent = e.message;
  } finally {
    $("#cmt-send").disabled = false;
  }
}
$("#cmt-cancel").addEventListener("click", closeCmt);
$("#cmt-send").addEventListener("click", sendCmt);
addEventListener("keydown", e => {
  if ($("#cmt-modal").hidden) return;
  if (e.key === "Escape") closeCmt();
  if (e.key === "Enter" && (e.ctrlKey || e.metaKey)) sendCmt();
});
window.__openCmt = openCmt; // 디버그용

// ── 조작 ───────────────────────────────────────────
$("#btn-text").addEventListener("click", () => {
  const s = tubeSlug();
  location.href = s ? "/txt/" + s + "/" : "/txt/";
});
$("#btn-pico").addEventListener("click", () => {
  if ($("#screen").classList.contains("off")) powerOn(tubeSlug(), true);
});
$("#btn-power").addEventListener("click", () => {
  if ($("#screen").classList.contains("off")) {
    powerOn(tubeSlug(), true);
  } else if (warpActive && offT === 0) {
    tweenOff(1, 380, powerOff); // CRT 꺼짐: 세로 붕괴 → 점 → 소등
  } else if (!warpActive) {
    powerOff();
  }
});

addEventListener("hashchange", () => {
  const h = location.hash.slice(1);
  if (h === "txt" || h.startsWith("txt/")) {
    location.replace("/txt/" + (h.startsWith("txt/") ? h.slice(4) + "/" : ""));
  } else if (h) {
    goPico(h, true);
  }
});

// 태그라인은 콘텐츠 데이터(/content/index.json)에서 최신값으로 갱신
getIndex().then(idx => {
  if (idx.tagline) $("#tagline").textContent = idx.tagline;
}).catch(() => {});

// ── 진입 라우팅: #slug → pico 딥링크, #txt/slug → 정적 텍스트 페이지 ──
const h0 = location.hash.slice(1);
if (h0 === "txt" || h0.startsWith("txt/")) {
  location.replace("/txt/" + (h0.startsWith("txt/") ? h0.slice(4) + "/" : ""));
} else {
  goPico(h0 || null, false);
}
})();
</script>
</body>
</html>
